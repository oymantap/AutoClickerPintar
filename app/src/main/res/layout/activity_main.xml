<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="#0F0F12">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RYCL LABS"
        android:textColor="#2979FF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Auto Clicker Pro"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Konfigurasi hak akses sistem untuk mengaktifkan engine engine multi-target simulasi klik otomatis."
        android:textColor="#666677"
        android:textSize="13sp"
        android:layout_marginBottom="32dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="#16161F"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Izin Lapisan Atas (Overlay)"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_status_overlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Dibutuhkan"
                    android:textColor="#FF3366"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Memungkinkan panel kontrol melayang di atas game target lu."
                android:textColor="#8A8A9E"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>
                
            <Button
                android:id="@+id/btn_permit_overlay"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#FF3366"
                android:text="Izinkan Overlay"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        app:cardBackgroundColor="#16161F"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aksesibilitas Core"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_status_accessibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="Dibutuhkan"
                    android:textColor="#00E676"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mengizinkan engine menyimulasikan ketukan fisik tanpa ghost touch secara presisi."
                android:textColor="#8A8A9E"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>
                
            <Button
                android:id="@+id/btn_permit_accessibility"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:backgroundTint="#00E676"
                android:text="Aktifkan Service"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                app:cornerRadius="10dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btn_start_service"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#2979FF"
        android:text="LAUNCH FLOATING PANEL"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        app:cornerRadius="14dp" />

</LinearLayout>
