<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#FA1A1A1A"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="10dp">

    <View
        android:id="@+id/panel_drag_handle"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_speed"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:hint="Jeda (ms)"
        android:inputType="number"
        android:text="200"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/et_target_num"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:hint="Angka Berhenti"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center">

        <Button
            android:id="@+id/btn_add_target"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:text="+"
            android:backgroundTint="#2979FF"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_remove_target"
            android:layout_width="45dp"
            android:layout_height="40dp"
            android:text="-"
            android:layout_marginStart="4dp"
            android:backgroundTint="#555555"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_start"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#00E676"
        android:text="START"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_close_panel"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="4dp"
        android:backgroundTint="#FF3366"
        android:text="CLOSE WIDGET"
        android:textColor="#FFFFFF"
        android:textSize="11sp" />
</LinearLayout>
